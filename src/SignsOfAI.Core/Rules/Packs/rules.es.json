  "patterns": [
    { "id": "rhet.no-solo-sino",   "category": "Rhetorical", "regex": "\\bno s[oó]lo\\b[^.?!\\n]{1,80}?\\bsino (también|que también|que)\\b", "weight": 5.0, "severity": "High",   "message": "Paralelismo negativo (“no solo… sino también…”).", "suggestion": "Divídelo en dos frases claras o empieza por lo más fuerte." },
    { "id": "rhet.no-se-trata",    "category": "Rhetorical", "regex": "\\bno se trata (solo|s[oó]lo|únicamente|solamente) de\\b", "weight": 5.0, "severity": "High", "message": "Paralelismo negativo (“no se trata solo de X, sino de Y”).", "suggestion": "Afirma directamente lo que sí es." },
    { "id": "rhet.era-digital",    "category": "Rhetorical", "regex": "\\ben (la |el )?(era|mundo|[ée]poca) (digital|actual|moderna|moderno)\\b", "weight": 4.5, "severity": "High", "message": "Apertura cliché (“en la era digital actual”).", "suggestion": "Abre con un dato, una afirmación o una escena concreta." },
    { "id": "rhet.cabe-destacar",  "category": "Rhetorical", "regex": "\\bcabe (destacar|mencionar|se[ñn]alar|resaltar|recordar) que\\b", "weight": 4.0, "severity": "Medium", "message": "Muletilla de relleno (“cabe destacar que”).", "suggestion": "Bórralo y afirma el punto directamente." },
    { "id": "rhet.es-importante",  "category": "Rhetorical", "regex": "\\bes importante (destacar|se[ñn]alar|recordar|mencionar|tener en cuenta|considerar)\\b", "weight": 3.5, "severity": "Medium", "message": "Muletilla de relleno (“es importante destacar…”).", "suggestion": "Si es importante, dilo sin el preámbulo." },
    { "id": "rhet.vale-la-pena",   "category": "Rhetorical", "regex": "\\bvale la pena (mencionar|destacar|se[ñn]alar|recordar)\\b", "weight": 3.5, "severity": "Medium", "message": "Muletilla de relleno (“vale la pena mencionar”).", "suggestion": "Elimínala; ve directo al punto." },
    { "id": "rhet.vasto-mundo",    "category": "Rhetorical", "regex": "\\ben el (vasto |amplio |fascinante )?(mundo|[áa]mbito|panorama|universo|campo) de\\b", "weight": 3.5, "severity": "Medium", "message": "Marco de relleno (“en el vasto mundo de…”).", "suggestion": "Nombra el tema directamente: “en la medicina…”." },
    { "id": "syn.testimonio-de",   "category": "Syntactic", "regex": "\\bun (claro |verdadero |auténtico )?testimonio de\\b", "weight": 5.0, "severity": "High", "message": "Inflación retórica (“un testimonio de…”).", "suggestion": "Di qué demuestra: “muestra…”, “prueba…”." },
    { "id": "syn.juega-papel",     "category": "Syntactic", "regex": "\\bjuega un papel (crucial|fundamental|clave|primordial|vital|importante|decisivo)\\b", "weight": 3.5, "severity": "Medium", "message": "Construcción inflada (“juega un papel crucial”).", "suggestion": "Di qué hace: “X impulsa Y”, no “X juega un papel crucial en Y”." },
    { "id": "syn.se-erige",        "category": "Syntactic", "regex": "\\bse (erige|alza|posiciona|consolida) como\\b", "weight": 4.0, "severity": "Medium", "message": "Evasión de cópula (“se erige como…” en vez de “es…”).", "suggestion": "Usa “es” salvo que el verbo aporte significado real." },
    { "id": "syn.rico-tapiz",      "category": "Syntactic", "regex": "\\b(rico|intrincado|vibrante|complejo) (tapiz|entramado|mosaico) de\\b", "weight": 5.5, "severity": "High", "message": "Metáfora cliché (“un rico tapiz de…”).", "suggestion": "Suelta la metáfora y nombra los elementos." },
    { "id": "rhet.embarcate",      "category": "Rhetorical", "regex": "\\bemb[aá]rcate en (un|una|este|esta)\\b|\\bsum[eé]rgete en\\b", "weight": 3.5, "severity": "Medium", "message": "Llamada de relleno (“embárcate en este viaje”).", "suggestion": "Empieza directo; borra el rodeo." },
    { "id": "rhet.en-resumen",     "category": "Rhetorical", "regex": "\\ben (resumen|conclusi[óo]n|síntesis)\\b|\\bpara concluir\\b", "weight": 2.5, "severity": "Low", "message": "Etiqueta de cierre formulaica (“en conclusión”).", "suggestion": "Cierra con tu idea, no con un letrero." },
    { "id": "rhet.por-un-lado",    "category": "Rhetorical", "regex": "\\bpor un lado\\b", "weight": 3.0, "severity": "Medium", "message": "Marco simétrico (“por un lado… por otro”) — falso equilibrio.", "suggestion": "Si la evidencia favorece un lado, dilo." },
    { "id": "rhet.regla-de-tres",  "category": "Rhetorical", "regex": "\\b(\\w+), (\\w+) y (\\w+)[.,;]", "weight": 1.2, "severity": "Info", "message": "Posible “regla de tres” — la IA abusa de los tríos.", "suggestion": "Bien de vez en cuando; si todas las listas son de tres, varía." }
