  "patterns": [
    { "id": "rhet.not-just",       "category": "Rhetorical", "regex": "\\bit'?s not (just|only|merely|about)\\b[^.?!\\n]{1,60}?,\\s*it'?s\\b", "weight": 6.0, "severity": "High",   "message": "Negative parallelism (“it's not just X, it's Y”) — feigns depth.", "suggestion": "State the claim directly. Cut the “not just… it's…” frame." },
    { "id": "rhet.not-only-but",   "category": "Rhetorical", "regex": "\\bnot only\\b[^.?!\\n]{1,80}?\\bbut (also|it also)\\b", "weight": 5.0, "severity": "Medium", "message": "Negative parallelism (“not only… but also…”).", "suggestion": "Split into two plain statements, or lead with the stronger point." },
    { "id": "rhet.worth-noting",   "category": "Rhetorical", "regex": "\\bit(('?s)| is) worth noting that\\b", "weight": 4.0, "severity": "Medium", "message": "Hedging filler (“it's worth noting that”).", "suggestion": "Delete it and state the point outright." },
    { "id": "rhet.important-note",  "category": "Rhetorical", "regex": "\\bit is important to (note|remember|consider|understand)\\b", "weight": 3.5, "severity": "Medium", "message": "Hedging filler (“it is important to note…”).", "suggestion": "If it's important, just say it. Drop the preamble." },
    { "id": "rhet.in-todays",      "category": "Rhetorical", "regex": "\\bin today'?s (digital |modern |fast-paced |ever-changing )?(age|world|era|landscape|society)\\b", "weight": 4.5, "severity": "High", "message": "Cliché opener (“in today's digital age”).", "suggestion": "Open with a specific fact, claim, or scene instead." },
    { "id": "rhet.in-realm",       "category": "Rhetorical", "regex": "\\bin the (realm|world|landscape) of\\b", "weight": 3.5, "severity": "Medium", "message": "Filler frame (“in the realm of…”).", "suggestion": "Name the field directly: “in medicine…” not “in the realm of medicine…”." },
    { "id": "rhet.that-being-said","category": "Rhetorical", "regex": "\\bthat being said\\b|\\bwith that being said\\b", "weight": 2.5, "severity": "Low", "message": "Transitional padding (“that being said”).", "suggestion": "Use “but”, “still”, or nothing." },
    { "id": "rhet.when-it-comes",  "category": "Rhetorical", "regex": "\\bwhen it comes to\\b", "weight": 2.5, "severity": "Low", "message": "Padding phrase (“when it comes to”).", "suggestion": "Often deletable: “when it comes to pricing, it's…” → “pricing is…”." },
    { "id": "rhet.on-one-hand",    "category": "Rhetorical", "regex": "\\bon (the )?one hand\\b", "weight": 3.0, "severity": "Medium", "message": "Symmetrical framing (“on one hand… on the other”) — false balance.", "suggestion": "If the evidence favors one side, say so. Don't force a two-sided frame." },
    { "id": "rhet.in-conclusion",  "category": "Rhetorical", "regex": "\\bin conclusion\\b|\\bto sum up\\b|\\bin summary\\b", "weight": 2.5, "severity": "Low", "message": "Formulaic wrap-up label.", "suggestion": "End with your actual point, not a signpost." },
    { "id": "rhet.dive-in",        "category": "Rhetorical", "regex": "\\blet'?s (dive|delve) (in|into)\\b", "weight": 3.5, "severity": "Medium", "message": "Filler call-to-action (“let's dive in”).", "suggestion": "Just start. Delete the runway." },
    { "id": "rhet.rule-of-three",  "category": "Rhetorical", "regex": "\\b(\\w+), (\\w+),? and (\\w+)[.,;]", "weight": 1.2, "severity": "Info", "message": "Possible “rule of three” — AI defaults to tricolons.", "suggestion": "Fine occasionally; if every list is three items, vary the count." },
    { "id": "syn.serves-as",       "category": "Syntactic", "regex": "\\b(serves|stands|acts|functions) as (a|an|the)\\b", "weight": 3.5, "severity": "Medium", "message": "Copula avoidance (“serves as a…” instead of “is a…”).", "suggestion": "Use “is”/“are” unless the verb adds real meaning." },
    { "id": "syn.testament-to",    "category": "Syntactic", "regex": "\\b(stands|is) as a testament to\\b|\\ba testament to\\b", "weight": 5.0, "severity": "High", "message": "Copula inflation (“a testament to…”).", "suggestion": "Say what it proves plainly, e.g. “shows…” or “proves…”." },
    { "id": "syn.plays-role",      "category": "Syntactic", "regex": "\\bplays a (vital|crucial|key|pivotal|significant|central|major) role\\b", "weight": 3.5, "severity": "Medium", "message": "Inflated construction (“plays a crucial role”).", "suggestion": "Say what it does: “X drives Y”, not “X plays a crucial role in Y”." },
    { "id": "syn.rich-tapestry",   "category": "Syntactic", "regex": "\\b(rich|intricate|vibrant|complex) tapestry of\\b", "weight": 5.5, "severity": "High", "message": "Cliché metaphor (“rich tapestry of…”).", "suggestion": "Drop the metaphor and name the elements directly." },
    { "id": "rhet.false-range",    "category": "Rhetorical", "regex": "\\bfrom (ancient|the birth of|the smallest|humble|the dawn of|the depths of)\\b[^.?!\\n]{1,50}?\\bto\\b", "weight": 3.5, "severity": "Medium", "message": "Possible “false range” (“from X to Y”) inflating scope.", "suggestion": "Keep the range only if the span in between is genuinely relevant." }
  ]
}
