@page "/"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using SignsOfAI.Core
@using SignsOfAI.Core.Documents
@using SignsOfAI.Core.Model
@using SignsOfAI.Core.Rules
@using SignsOfAI.Web.Components
@using SignsOfAI.Web.Services
@inject AiWritingAnalyzer Analyzer
@inject HumanizerService Humanizer
@inject BrowserStorage Storage
@inject CatalogStore Catalogs
@inject IJSRuntime JS

<PageTitle>Signs of AI Writing — detect & de-AI-ify your text</PageTitle>

<header class="hero">
    <p class="tagline">
        Paste, upload, or just start typing. We flag the tells of AI writing — overused words,
        rhetorical crutches, robotic rhythm — <strong>live, as you write</strong>, and show you how to fix each one.
    </p>
    <p class="privacy">🔒 Analysis runs entirely in your browser. Your text never leaves your device.</p>
</header>

<section class="editor card">
    <div class="toolbar">
        <label class="field">
            Language
            <select @bind="_language" @bind:after="OnControlChanged">
                <option value="auto">Auto-detect</option>
                <option value="en">English</option>
                <option value="es">Español</option>
            </select>
        </label>
        <label class="upload-btn" title="Upload a .docx, .txt or .md document">
            📄 Upload document
            <InputFile OnChange="OnFileSelected" accept=".docx,.txt,.md,.markdown,.text,.csv,.log" />
        </label>
        <div class="samples">
            <span>Try a sample:</span>
            <button class="link" @onclick="@(() => LoadSample(SampleEn))">AI (EN)</button>
            <button class="link" @onclick="@(() => LoadSample(SampleEs))">IA (ES)</button>
            <button class="link" @onclick="@(() => LoadSample(SampleHuman))">Human</button>
        </div>
        <span class="live-pill" title="Analysis updates automatically as you type"><span class="live-dot"></span> Live</span>
        <div class="counter">@WordCount words</div>
    </div>

    @if (_fileNote is not null) { <p class="file-note">@_fileNote</p> }

    <textarea @bind="_text" @bind:event="oninput" @bind:after="OnTextChanged"
              placeholder="Start typing here, paste your text, or upload a document above…"
              spellcheck="false"></textarea>
    <p class="hint doc-hint">Full documents welcome — including Word (<code>.docx</code>). For PDF, copy-paste the text.</p>

    <div class="actions">
        <button class="ghost" @onclick="Clear" disabled="@string.IsNullOrEmpty(_text)">Clear</button>
        <button class="ghost" @onclick="@(() => _showCatalogs = !_showCatalogs)">
            📚 Catalogs@(Catalogs.Catalogs.Count > 0 ? $" ({Catalogs.Catalogs.Count})" : "")
        </button>
        <button class="ghost settings-toggle" @onclick="@(() => _showSettings = !_showSettings)">⚙ AI provider</button>
    </div>

    @if (_showCatalogs)
    {
        <div class="settings">
            <p class="hint">
                <strong>Bring your own catalog.</strong> Add your team's banned words or a full custom rule-pack.
                Catalogs are stored only in your browser and merge on top of the built-in packs — live.
            </p>

            <div class="catalog-list">
                <div class="catalog-row builtin"><span>✓ English (built-in)</span></div>
                <div class="catalog-row builtin"><span>✓ Español (built-in)</span></div>
                @foreach (var c in Catalogs.Catalogs)
                {
                    <div class="catalog-row">
                        <label class="cat-toggle">
                            <input type="checkbox" checked="@c.Enabled" @onchange="@(() => ToggleCatalog(c))" />
                            <span>@c.Name</span>
                        </label>
                        <span class="cat-meta">@c.RuleCount rule@(c.RuleCount == 1 ? "" : "s") · @(c.Language == "*" ? "any" : c.Language)</span>
                        <button class="link danger" @onclick="@(() => RemoveCatalog(c))">remove</button>
                    </div>
                }
            </div>

            <div class="catalog-add">
                <div class="add-tabs">
                    <button class="filter @(_catMode == "words" ? "on" : "")" @onclick="@(() => _catMode = "words")">Quick: banned words</button>
                    <button class="filter @(_catMode == "json" ? "on" : "")" @onclick="@(() => _catMode = "json")">Advanced: import JSON</button>
                </div>

                @if (_catMode == "words")
                {
                    <input placeholder="Catalog name — e.g. Company style guide" @bind="_newCatName" @bind:event="oninput" />
                    <textarea class="cat-words" placeholder="Words or phrases to flag, separated by commas or new lines…&#10;synergy, circle back, low-hanging fruit" @bind="_newCatWords" @bind:event="oninput"></textarea>
                    <button class="primary" @onclick="AddBannedWords" disabled="@string.IsNullOrWhiteSpace(_newCatWords)">Add catalog</button>
                }
                else
                {
                    <input placeholder="Catalog name" @bind="_newCatName" @bind:event="oninput" />
                    <textarea class="cat-words mono" placeholder='{ "language": "*", "lexical": [ { "id": "x", "terms": ["foo"], "suggestion": "bar" } ], "patterns": [] }' @bind="_newCatJson" @bind:event="oninput"></textarea>
                    @if (_catError is not null) { <p class="hint danger-text">@_catError</p> }
                    <div class="key-row">
                        <button class="primary" @onclick="AddJsonCatalog" disabled="@string.IsNullOrWhiteSpace(_newCatJson)">Import</button>
                        <button class="ghost" @onclick="DownloadTemplate">Download English pack as a template</button>
                    </div>
                }
            </div>
        </div>
    }

    @if (_showSettings)
    {
        <div class="settings">
            <p class="hint">
                Optional: connect an AI provider to enable one-click “Humanize”. Credentials are stored
                only in your browser and are sent directly to the provider — never to us.
            </p>
            <label class="field">
                Provider
                <select @bind="_settings.Provider">
                    <option value="@AiProvider.Anthropic">Anthropic (Claude)</option>
                    <option value="@AiProvider.OpenAI">OpenAI</option>
                    <option value="@AiProvider.AzureOpenAI">Azure OpenAI</option>
                    <option value="@AiProvider.DeepSeek">DeepSeek</option>
                    <option value="@AiProvider.Ollama">Ollama (local)</option>
                </select>
            </label>

            @switch (_settings.Provider)
            {
                case AiProvider.Anthropic:
                    <div class="key-row">
                        <input type="password" placeholder="sk-ant-…" @bind="_settings.ApiKey" @bind:event="oninput" />
                    </div>
                    <p class="hint sub">Uses <code>claude-opus-4-8</code>. Works directly from the browser. Key from
                        <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener">console.anthropic.com</a>.</p>
                    break;

                case AiProvider.OpenAI:
                    <div class="azure-grid">
                        <input placeholder="Model — e.g. gpt-4o" @bind="_settings.Model" @bind:event="oninput" />
                        <input type="password" placeholder="API key — sk-…" @bind="_settings.ApiKey" @bind:event="oninput" />
                    </div>
                    <p class="hint sub">Key from
                        <a href="https://platform.openai.com/api-keys" target="_blank" rel="noopener">platform.openai.com</a>.
                        Called directly from the browser.</p>
                    break;

                case AiProvider.AzureOpenAI:
                    <div class="azure-grid">
                        <input placeholder="Endpoint — https://your-resource.openai.azure.com" @bind="_settings.AzureEndpoint" @bind:event="oninput" />
                        <input placeholder="Deployment name — e.g. gpt-4o" @bind="_settings.AzureDeployment" @bind:event="oninput" />
                        <input placeholder="API version" @bind="_settings.AzureApiVersion" @bind:event="oninput" />
                        <input type="password" placeholder="API key" @bind="_settings.ApiKey" @bind:event="oninput" />
                    </div>
                    <p class="hint sub">For your own <strong>Azure AI</strong> resource. Must allow this site's origin (CORS).</p>
                    break;

                case AiProvider.DeepSeek:
                    <div class="azure-grid">
                        <input placeholder="Model — e.g. deepseek-chat" @bind="_settings.Model" @bind:event="oninput" />
                        <input type="password" placeholder="API key — sk-…" @bind="_settings.ApiKey" @bind:event="oninput" />
                    </div>
                    <p class="hint sub">Key from
                        <a href="https://platform.deepseek.com/api_keys" target="_blank" rel="noopener">platform.deepseek.com</a>.</p>
                    break;

                case AiProvider.Ollama:
                    <div class="azure-grid">
                        <input placeholder="Base URL — http://localhost:11434" @bind="_settings.OllamaBaseUrl" @bind:event="oninput" />
                        <input placeholder="Model — e.g. llama3.1" @bind="_settings.Model" @bind:event="oninput" />
                    </div>
                    <p class="hint sub">🖥️ Run a model <strong>on your own machine</strong> — no cloud, no key. Best when you run
                        SignsOfAI locally; start Ollama with <code>OLLAMA_ORIGINS=* ollama serve</code>. From this hosted
                        HTTPS site the browser may block calls to <code>http://localhost</code>.</p>
                    break;
            }

            <div class="key-row">
                <button class="ghost" @onclick="SaveSettings">Save</button>
                <button class="ghost" @onclick="ForgetSettings">Forget</button>
                @if (_settingsSaved) { <span class="saved-note">✓ Saved in this browser</span> }
            </div>
        </div>
    }
</section>

@if (_result is not null)
{
    var r = _result;
    <section class="results">
        <div class="summary card">
            <div class="score-ring @ScoreClass(r.OverallScore)"
                 style="--pct:@r.OverallScore.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                <div class="score-inner">
                    <span class="score-num">@Math.Round(r.OverallScore)</span>
                    <span class="score-of">/100</span>
                </div>
            </div>
            <div class="verdict">
                <h2 class="@ScoreClass(r.OverallScore)">@r.Verdict</h2>
                <p>@r.Findings.Count signal@(r.Findings.Count == 1 ? "" : "s") found · analyzed as
                    <strong>@(r.Language == "es" ? "Español" : "English")</strong></p>
                <div class="cat-chips">
                    @foreach (var c in r.CategoryScores.Where(c => c.FindingCount > 0))
                    {
                        <span class="chip chip-@Highlighter.CategoryClass(c.Category)">
                            @Highlighter.CategoryLabel(c.Category) <b>@c.FindingCount</b>
                        </span>
                    }
                </div>
                <div class="summary-actions">
                    <button class="primary humanize-btn" @onclick="Humanize" disabled="@_humanizing">
                        @(_humanizing ? "Humanizing…" : "✨ Humanize with AI")
                    </button>
                    <button class="ghost" @onclick="ShowCard">📸 Share card</button>
                </div>
            </div>
        </div>

        @if (_showCard)
        {
            <div class="card share-preview">
                <div class="humanized-head">
                    <h3>Shareable card</h3>
                    <div>
                        <button class="primary" @onclick="DownloadCard">⬇ Download PNG</button>
                        <button class="ghost" @onclick="@(() => _showCard = false)">Close</button>
                    </div>
                </div>
                <canvas @ref="_cardCanvas" class="share-canvas"></canvas>
            </div>
        }

        <div class="stats card">
            <div class="stat"><span class="stat-label">Words</span><span class="stat-val">@r.Statistics.WordCount</span></div>
            <div class="stat"><span class="stat-label">Sentences</span><span class="stat-val">@r.Statistics.SentenceCount</span></div>
            <div class="stat"><span class="stat-label">Avg length</span><span class="stat-val">@r.Statistics.MeanSentenceLength</span></div>
            <div class="stat" title="Sentence-length variation. Low = machine-like uniformity.">
                <span class="stat-label">Burstiness</span>
                <span class="stat-val @(r.Statistics.Burstiness < 0.45 && r.Statistics.SentenceCount >= 4 ? "warn" : "")">
                    @r.Statistics.Burstiness.ToString("0.00")
                </span>
            </div>
            <div class="stat"><span class="stat-label">Lexical diversity</span><span class="stat-val">@r.Statistics.LexicalDiversity.ToString("0.00")</span></div>
        </div>

        <div class="rhythm card">
            <h3>Sentence rhythm</h3>
            <p class="hint">Each bar is one sentence; height is its length. Flat &amp; grey = machine cadence · tall/short &amp; green = human variance.</p>
            <RhythmChart Stats="r.Statistics" />
        </div>

        @if (_humanizeError is not null)
        {
            <div class="card humanize-error">⚠️ Humanize failed: @_humanizeError</div>
        }
        @if (_humanized is not null)
        {
            <div class="card humanized">
                <div class="humanized-head">
                    <h3>✨ Humanized</h3>
                    <div>
                        @if (_humanizedResult is not null)
                        {
                            <span class="score-compare">
                                <span class="sc-num @ScoreClass(r.OverallScore)">@Math.Round(r.OverallScore)</span>
                                <span class="sc-arrow">→</span>
                                <span class="sc-num @ScoreClass(_humanizedResult.OverallScore)">@Math.Round(_humanizedResult.OverallScore)</span>
                                @{ var delta = r.OverallScore - _humanizedResult.OverallScore; }
                                @if (delta > 0.5) { <span class="sc-delta">−@Math.Round(delta)</span> }
                            </span>
                        }
                        <button class="ghost" @onclick="CopyHumanized">Copy</button>
                        <button class="ghost" @onclick="ReanalyzeHumanized">Use as input</button>
                    </div>
                </div>
                @if (_diff is not null)
                {
                    <div class="diff-grid">
                        <div class="diff-col">
                            <h4>Original</h4>
                            <div class="text-view diff-view">
                                @foreach (var seg in _diff.Where(s => s.Kind != DiffKind.Added))
                                {
                                    <span class="@(seg.Kind == DiffKind.Removed ? "d-del" : "")">@seg.Text </span>
                                }
                            </div>
                        </div>
                        <div class="diff-col">
                            <h4>Humanized</h4>
                            <div class="text-view diff-view">
                                @foreach (var seg in _diff.Where(s => s.Kind != DiffKind.Removed))
                                {
                                    <span class="@(seg.Kind == DiffKind.Added ? "d-add" : "")">@seg.Text </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="workspace">
            <div class="annotated card">
                <h3>Your text, annotated</h3>
                <p class="hint">Highlighted spans are AI tells — hover for the suggestion.</p>
                <div class="text-view">
                    @foreach (var seg in Highlighter.Build(_analyzedText, r.Findings))
                    {
                        if (seg.Finding is { } f)
                        {
                            <mark class="hl hl-@Highlighter.CategoryClass(f.Category)"
                                  title="@f.Message&#10;→ @f.Suggestion">@seg.Text</mark>
                        }
                        else
                        {
                            @seg.Text
                        }
                    }
                </div>
            </div>

            <div class="findings card">
                <h3>Recommendations (@r.Findings.Count)</h3>
                @if (r.Findings.Count == 0)
                {
                    <p class="empty">✅ No strong AI tells found. This reads mostly human — nice work.</p>
                }
                else
                {
                    <ul class="finding-list">
                        @foreach (var f in r.Findings)
                        {
                            <li class="finding sev-@f.Severity.ToString().ToLowerInvariant()">
                                <div class="finding-head">
                                    <span class="badge badge-@Highlighter.CategoryClass(f.Category)">@Highlighter.CategoryLabel(f.Category)</span>
                                    @if (!string.IsNullOrEmpty(f.MatchedText)) { <code>@f.MatchedText</code> }
                                    <span class="sev-tag">@f.Severity</span>
                                </div>
                                <p class="finding-msg">@f.Message</p>
                                <p class="finding-fix">💡 @f.Suggestion</p>
                                @if (!string.IsNullOrEmpty(f.Evidence)) { <p class="finding-evidence">@f.Evidence</p> }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </section>
}
else
{
    <p class="idle-hint">Start typing, paste, or upload a document — your AI-writing score appears here instantly.</p>
}

@code {
    private const string SettingsStorageKey = "signsofai.humanize.v3";
    private const long MaxFileBytes = 5 * 1024 * 1024;

    private string _text = string.Empty;
    private string _language = "auto";
    private AnalysisResult? _result;
    private string _analyzedText = string.Empty;
    private string? _fileNote;

    private CancellationTokenSource? _debounceCts;

    private bool _showSettings;
    private HumanizeSettings _settings = new();
    private bool _settingsSaved;

    private bool _humanizing;
    private string? _humanized;
    private AnalysisResult? _humanizedResult;
    private IReadOnlyList<DiffSegment>? _diff;
    private string? _humanizeError;

    // Custom catalogs UI
    private bool _showCatalogs;
    private string _catMode = "words";
    private string _newCatName = string.Empty;
    private string _newCatWords = string.Empty;
    private string _newCatJson = string.Empty;
    private string? _catError;

    // Share card
    private bool _showCard;
    private bool _cardNeedsDraw;
    private ElementReference _cardCanvas;

    private int WordCount =>
        string.IsNullOrWhiteSpace(_text) ? 0
        : _text.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;

    protected override async Task OnInitializedAsync()
    {
        await Catalogs.LoadAsync();

        var stored = await Storage.GetAsync(SettingsStorageKey);
        if (!string.IsNullOrEmpty(stored))
        {
            try
            {
                _settings = JsonSerializer.Deserialize(stored, LlmJsonContext.Default.HumanizeSettings) ?? new();
                _settingsSaved = true;
            }
            catch { _settings = new(); }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_cardNeedsDraw && _showCard && _result is not null)
        {
            _cardNeedsDraw = false;
            await JS.InvokeVoidAsync("signsofai.drawCard", _cardCanvas, BuildCardJson(_result));
        }
    }

    private async Task OnTextChanged()
    {
        _fileNote = null;
        _debounceCts?.Cancel();
        var cts = _debounceCts = new CancellationTokenSource();
        try { await Task.Delay(350, cts.Token); }
        catch (TaskCanceledException) { return; }
        if (cts.IsCancellationRequested) return;

        RunAnalysis();
        StateHasChanged();
    }

    private void OnControlChanged()
    {
        if (!string.IsNullOrWhiteSpace(_text)) RunAnalysis();
    }

    private void RunAnalysis()
    {
        if (string.IsNullOrWhiteSpace(_text))
        {
            _result = null;
            _analyzedText = string.Empty;
            ResetHumanize();
            _showCard = false;
            return;
        }
        _analyzedText = _text;
        _result = Analyzer.Analyze(_text, _language, Catalogs.EnabledPacks());
        ResetHumanize();
        _showCard = false;
    }

    private void ResetHumanize()
    {
        _humanized = null;
        _humanizedResult = null;
        _diff = null;
        _humanizeError = null;
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        if (file.Size > MaxFileBytes)
        {
            _fileNote = $"“{file.Name}” is too large (max 5 MB).";
            return;
        }
        try
        {
            if (file.Name.EndsWith(".docx", StringComparison.OrdinalIgnoreCase))
            {
                await using var docStream = file.OpenReadStream(MaxFileBytes);
                _text = await DocxTextExtractor.ExtractTextAsync(docStream);
            }
            else
            {
                using var reader = new StreamReader(file.OpenReadStream(MaxFileBytes));
                _text = await reader.ReadToEndAsync();
            }
            RunAnalysis();
            _fileNote = $"Loaded “{file.Name}” ({file.Size / 1024} KB).";
        }
        catch (Exception ex)
        {
            _fileNote = $"Could not read the file: {ex.Message}";
        }
    }

    private void Clear()
    {
        _text = string.Empty;
        RunAnalysis();
        _fileNote = null;
    }

    private void LoadSample(string sample)
    {
        _text = sample;
        _fileNote = null;
        RunAnalysis();
    }

    private async Task SaveSettings()
    {
        var json = JsonSerializer.Serialize(_settings, LlmJsonContext.Default.HumanizeSettings);
        await Storage.SetAsync(SettingsStorageKey, json);
        _settingsSaved = true;
    }

    private async Task ForgetSettings()
    {
        await Storage.RemoveAsync(SettingsStorageKey);
        _settings = new();
        _settingsSaved = false;
    }

    // ── custom catalogs ─────────────────────────────────────────────
    private async Task AddBannedWords()
    {
        await Catalogs.AddBannedWordsAsync(_newCatName, _newCatWords, "*");
        _newCatName = _newCatWords = string.Empty;
        RunAnalysis(); // apply live
    }

    private async Task AddJsonCatalog()
    {
        _catError = null;
        try
        {
            await Catalogs.AddJsonAsync(_newCatName, _newCatJson, "");
            _newCatName = _newCatJson = string.Empty;
            RunAnalysis();
        }
        catch (Exception ex) { _catError = "Invalid rule-pack JSON: " + ex.Message; }
    }

    private async Task ToggleCatalog(CustomCatalog c) { await Catalogs.ToggleAsync(c); RunAnalysis(); }
    private async Task RemoveCatalog(CustomCatalog c) { await Catalogs.RemoveAsync(c); RunAnalysis(); }

    private async Task DownloadTemplate() =>
        await JS.InvokeVoidAsync("signsofai.downloadText", "signsofai-en-template.json", RulePackLoader.Load("en").ToJson());

    // ── humanize ────────────────────────────────────────────────────
    private async Task Humanize()
    {
        if (_result is null) return;
        if (!_settings.IsConfigured())
        {
            _showSettings = true;
            _humanizeError = "Configure an AI provider (⚙ AI provider) to enable Humanize.";
            return;
        }

        _humanizing = true;
        ResetHumanize();
        StateHasChanged();

        var result = await Humanizer.HumanizeAsync(_analyzedText, _result.Language, _result.Findings, _settings);
        _humanizing = false;
        if (result.Success)
        {
            _humanized = result.Text;
            _humanizedResult = Analyzer.Analyze(_humanized, _language, Catalogs.EnabledPacks());
            _diff = WordDiff.Compute(_analyzedText, _humanized);
        }
        else _humanizeError = result.Error;
    }

    private async Task CopyHumanized()
    {
        if (_humanized is not null)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _humanized);
    }

    private void ReanalyzeHumanized()
    {
        if (_humanized is null) return;
        _text = _humanized;
        _fileNote = null;
        RunAnalysis();
    }

    // ── share card ──────────────────────────────────────────────────
    private void ShowCard()
    {
        _showCard = true;
        _cardNeedsDraw = true;
    }

    private async Task DownloadCard() =>
        await JS.InvokeVoidAsync("signsofai.downloadCanvas", _cardCanvas, "signsofai-score.png");

    private static string BuildCardJson(AnalysisResult r)
    {
        var data = new ShareCardData(
            Score: r.OverallScore,
            ScoreColor: ScoreHex(r.OverallScore),
            Verdict: r.Verdict,
            Signals: r.Findings.Count,
            Language: r.Language == "es" ? "Español" : "English",
            Categories: r.CategoryScores.Where(c => c.FindingCount > 0)
                .Select(c => new CardCategory(Highlighter.CategoryLabel(c.Category), c.FindingCount, Highlighter.CategoryHex(c.Category)))
                .ToArray(),
            Words: r.Statistics.WordCount,
            Sentences: r.Statistics.SentenceCount,
            Burstiness: r.Statistics.Burstiness.ToString("0.00"),
            Lengths: r.Statistics.SentenceLengths.ToArray());
        return JsonSerializer.Serialize(data, ShareCardJsonContext.Default.ShareCardData);
    }

    private static string ScoreClass(double score) => score switch
    {
        >= 70 => "danger",
        >= 45 => "warn",
        >= 20 => "notice",
        _ => "good",
    };

    private static string ScoreHex(double score) => score switch
    {
        >= 70 => "#dc2626",
        >= 45 => "#ea580c",
        >= 20 => "#ca8a04",
        _ => "#16a34a",
    };

    private const string SampleEn =
        "In today's digital age, we must delve into the rich tapestry of modern innovation. It's worth " +
        "noting that this multifaceted and nuanced approach serves as a testament to human progress. " +
        "It's not just a tool, it's a pivotal, transformative solution that fosters growth and unlocks " +
        "potential. Moreover, by leveraging cutting-edge technology, organizations can seamlessly navigate " +
        "the ever-evolving landscape and showcase their commitment to excellence.";

    private const string SampleEs =
        "En la era digital actual, debemos sumergirnos en el vasto mundo de la innovación. Cabe destacar que " +
        "este enfoque multifacético y matizado se erige como un testimonio del progreso humano. No solo es una " +
        "herramienta, sino también una solución crucial y transformadora que fomenta el crecimiento. Además, al " +
        "aprovechar la tecnología de vanguardia, las organizaciones juegan un papel fundamental en el panorama actual.";

    private const string SampleHuman =
        "The bus was late again. I stood there for twelve minutes, coffee going cold in my hands, watching the " +
        "rain streak sideways across the shelter. Then — of course — it rolled right past without stopping. So I " +
