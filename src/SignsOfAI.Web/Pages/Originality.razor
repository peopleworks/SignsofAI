    // ── highlight builder ────────────────────────────────────────────────────
    private readonly record struct Seg(string Text, bool Match);

    /// <summary>Splits <paramref name="text"/> into matched / unmatched segments given the (possibly
    /// unordered, overlapping) spans for one side of a pair. Spans are sorted and merged first.</summary>
    private static IEnumerable<Seg> Segments(string text, IEnumerable<TextSpan> spans)
    {
        var merged = new List<(int Start, int End)>();
        foreach (var s in spans.Where(s => s.Length > 0).OrderBy(s => s.Start))
        {
            if (merged.Count > 0 && s.Start <= merged[^1].End)
            {
                var last = merged[^1];
                if (s.End > last.End) merged[^1] = (last.Start, s.End);
            }
            else merged.Add((s.Start, s.End));
        }

        int cursor = 0;
        foreach (var (start, end) in merged)
        {
            if (start > cursor) yield return new Seg(text[cursor..start], false);
            yield return new Seg(text[start..end], true);
            cursor = end;
        }
        if (cursor < text.Length) yield return new Seg(text[cursor..], false);
    }

    private static string Pct(double v) => (v * 100).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture) + "%";

    private static string Band(double overlap) => overlap switch
    {
        >= 0.60 => "b-pred",   // amber/red — high overlap
        >= 0.30 => "b-typ",    // brand — notable
        >= 0.10 => "b-some",   // light — some
        _ => "b-var",          // green — little/none
    };

    private static string BandTitle(double overlap) => overlap switch
    {
        >= 0.60 => "High overlap — likely a shared source",
        >= 0.30 => "Notable overlap — worth a closer look",
        >= 0.10 => "Some shared phrasing",
        _ => "Little to no overlap",
    };
}
