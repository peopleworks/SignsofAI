@page "/originality"
@using Microsoft.AspNetCore.Components.Forms
@using SignsOfAI.Core.Documents
@using SignsOfAI.Core.Model
@using SignsOfAI.Core.Originality
@using SignsOfAI.Core.Text
@using SignsOfAI.Web.Services
@inject OriginalityChecker Checker
@inject PerplexityClient Perplexity
@inject EmbeddingClient Embedding
@inject WebCheckClient WebCheck
@inject BrowserStorage Storage

<PageTitle>Originality checker — find shared passages between documents</PageTitle>

<header class="hero">
    <h1>Originality checker</h1>
    <p class="tagline">
        Did they write it — or copy it? Drop in two or more documents (essays, a thesis and its sources,
        a batch of student submissions) and we surface the passages they <strong>share</strong>, highlighted
        as evidence. Edits like changed capitalization or accents don't hide a copy. <strong>You judge.</strong>
    </p>
    <p class="privacy"><Icon Name="lock" /> Runs entirely in your browser. Your documents never leave your device — nothing is uploaded.</p>
</header>

<section class="orig-inputs">
    @foreach (var doc in _docs)
    {
        var d = doc;
        <div class="orig-doc card" @key="d.Id">
            <div class="orig-doc-head">
                <input class="orig-title" placeholder="@($"Document {_docs.IndexOf(d) + 1} — name or author")"
                       @bind="d.Title" @bind:event="oninput" />
                <label class="upload-btn sm" title="Upload a .docx, .txt or .md document">
                    <Icon Name="upload" /> Upload
                    <InputFile OnChange="@(e => OnFileSelected(e, d))" accept=".docx,.txt,.md,.markdown,.text" />
                </label>
                <span class="orig-wc">@WordsOf(d.Text) words</span>
                <button class="link orig-webbtn" title="Check the web for this document's distinctive passages"
                        disabled="@string.IsNullOrWhiteSpace(d.Text)" @onclick="@(() => ToggleWeb(d))">
                    <Icon Name="globe" /> Web check
                </button>
                @if (_docs.Count > 2)
                {
                    <button class="icon-btn" title="Remove this document" @onclick="@(() => RemoveDoc(d))"><Icon Name="close" /></button>
                }
            </div>
            @if (d.Note is not null) { <p class="file-note">@d.Note</p> }
            <textarea class="orig-text" placeholder="Paste or type the document text here…"
                      spellcheck="false" @bind="d.Text" @bind:event="oninput"></textarea>

            @if (d.ShowWeb)
            {
                <div class="orig-web">
                    <p class="hint">
                        We can't index the whole web — so instead of guessing, here are this document's most
                        <strong>distinctive passages</strong>. Search each one to see if it already appears online.
                        Nothing is sent anywhere until <em>you</em> click a search. <strong>You judge.</strong>
                    </p>

                    @if (_webSearchReady)
                    {
                        <div class="orig-web-auto">
                            <span class="orig-auto-badge"><Icon Name="globe" /> Auto web search: ON</span>
                            <button class="ghost sm" @onclick="@(() => RunAutoWebCheck(d))" disabled="@(d.WebSearching || d.WebPhrases is not { Count: > 0 })">
                                @(d.WebSearching ? "Searching the web…" : d.WebHits is not null ? "Search again" : "Search the web automatically")
                            </button>
                        </div>
                        @if (d.WebError is not null) { <p class="orig-para-status err">@d.WebError</p> }
                        @if (d.WebHits is not null)
                        {
                            @foreach (var ph in d.WebHits)
                            {
                                <div class="orig-web-hits">
                                    <q class="orig-web-q">@ph.Phrase</q>
                                    @if (ph.Hits.Length == 0)
                                    {
                                        <p class="empty sm">No web pages found for this passage.</p>
                                    }
                                    else
                                    {
                                        <ul class="orig-hitlist">
                                            @foreach (var h in ph.Hits)
                                            {
                                                <li>
                                                    <a href="@h.Url" target="_blank" rel="noopener">@(string.IsNullOrWhiteSpace(h.Title) ? h.Url : h.Title)</a>
                                                    @if (h.Verbatim) { <span class="orig-verbatim">verbatim match</span> }
                                                    @if (!string.IsNullOrWhiteSpace(h.Snippet)) { <span class="orig-hit-snip">@h.Snippet</span> }
                                                </li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        }
                    }

                    @if (d.WebPhrases is { Count: > 0 })
                    {
                        <p class="hint orig-manual-h">@(_webSearchReady ? "Or search manually:" : "")</p>
                        <ul class="orig-web-list">
                            @foreach (var ph in d.WebPhrases)
                            {
                                <li>
                                    <q>@ph.Phrase</q>
                                    <span class="orig-web-links">
                                        <a href="@SearchUrl("google", ph.Phrase)" target="_blank" rel="noopener">Google</a>
                                        <a href="@SearchUrl("bing", ph.Phrase)" target="_blank" rel="noopener">Bing</a>
                                        <a href="@SearchUrl("ddg", ph.Phrase)" target="_blank" rel="noopener">DuckDuckGo</a>
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="empty">Not enough distinctive text here to spot-check.</p>
                    }
                </div>
            }
        </div>
    }

    <div class="orig-actions">
        <button class="ghost" @onclick="AddDoc"><Icon Name="plus" /> Add document</button>
        <label class="upload-btn" title="Add many documents at once — a whole cohort">
            <Icon Name="upload" /> Add files
            <InputFile OnChange="OnBatchFiles" multiple accept=".docx,.txt,.md,.markdown,.text" />
        </label>
        <button class="ghost" @onclick="LoadExample">Load an example</button>
        <button class="ghost" @onclick="ClearAll">Clear</button>
        @if (_batchNote is not null) { <span class="hint">@_batchNote</span> }
        <button class="primary" @onclick="Compare" disabled="@(ReadyCount < 2)">
            <Icon Name="search" /> Compare @(ReadyCount >= 2 ? $"{ReadyCount} documents" : "")
        </button>
        @if (ReadyCount < 2) { <span class="hint">Add text to at least two documents.</span> }
    </div>
</section>

@if (_report is not null)
{
    var rep = _report;
    var top = rep.Pairs.Count > 0 ? rep.Pairs[0] : null;

    <section class="orig-results">
        @if (top is null || top.Overlap < 0.001)
        {
            <div class="card orig-summary b-var">
                <div class="orig-big"><Icon Name="check-circle" /></div>
                <div>
                    <h2>No meaningful overlap found</h2>
                    <p>Across @rep.DocumentCount documents, no shared passages of @rep.ShingleSize+ consecutive
                        words turned up. These read as independently written.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card orig-summary @Band(top.Overlap)">
                <div class="orig-big">@($"{top.Overlap:P0}")</div>
                <div>
                    <h2>@BandTitle(top.Overlap)</h2>
                    <p>
                        The strongest match: <strong>@top.TitleA</strong> ↔ <strong>@top.TitleB</strong> —
                        @($"{top.Overlap:P0}") of @(top.CoverageA >= top.CoverageB ? top.TitleA : top.TitleB)'s words
                        appear verbatim in the other (@top.SharedWords words across @top.Passages.Count
                        passage@(top.Passages.Count == 1 ? "" : "s")). We show the shared text below — the call is yours.
                    </p>
                </div>
            </div>
        }

        @if (rep.DocumentCount >= 3 && _overlap is not null)
        {
            <div class="card orig-matrix-card">
                <h3>Cohort overlap matrix</h3>
                <p class="hint">Every document against every other — darker means more shared text. Click a cell to inspect that pair.</p>
                <div class="orig-matrix-scroll">
                    <div class="orig-matrix" style="grid-template-columns: 1.7rem repeat(@rep.DocumentCount, minmax(1.7rem, 2.6rem));">
                        <div class="orig-mx-corner"></div>
                        @for (int j = 0; j < rep.DocumentCount; j++)
                        {
                            <div class="orig-mx-head" title="@rep.Titles[j]">@(j + 1)</div>
                        }
                        @for (int i = 0; i < rep.DocumentCount; i++)
                        {
                            var r = i;
                            <div class="orig-mx-rowhead" title="@rep.Titles[r]">@(r + 1)</div>
                            @for (int j = 0; j < rep.DocumentCount; j++)
                            {
                                var c = j;
                                if (r == c)
                                {
                                    <div class="orig-mx-cell self"></div>
                                }
                                else
                                {
                                    var v = _overlap[r][c];
                                    <button class="orig-mx-cell @(v > 0.0001 ? "hot" : "")"
                                            title="@rep.Titles[r] ↔ @rep.Titles[c]: @($"{v:P0}")"
                                            style="background: color-mix(in srgb, var(--danger) @(((int)Math.Round(v * 100)))%, transparent);"
                                            @onclick="@(() => SelectPairByCell(r, c))">@(v >= 0.10 ? $"{v:P0}" : "")</button>
                                }
                            }
                        }
                    </div>
                </div>
                <ol class="orig-legend">
                    @for (int i = 0; i < rep.DocumentCount; i++)
                    {
                        <li><span class="orig-legend-n">@(i + 1)</span> @rep.Titles[i]</li>
                    }
                </ol>
            </div>
        }

        @{
            int meaningful = rep.Pairs.Count(x => x.Overlap > 0.0001);
            int hiddenPairs = rep.Pairs.Count - meaningful;
        }
        <div class="card orig-pairs">
            <h3>Most similar pairs@(meaningful > 0 ? $" ({meaningful})" : "")</h3>
            <p class="hint">Ranked by overlap — the share of the more-copied document that appears in the other. Click a row to inspect the shared passages.</p>
            @if (meaningful == 0)
            {
                <p class="empty">No pair shares any passage of @rep.ShingleSize+ words.</p>
            }
            else
            {
                <div class="orig-pair-list">
                    @for (int i = 0; i < rep.Pairs.Count; i++)
                    {
                        var p = rep.Pairs[i];
                        if (p.Overlap <= 0.0001) { continue; }
                        var idx = i;
                        <button class="orig-pair @(idx == _selected ? "sel" : "")" @onclick="@(() => SelectPair(idx))">
                            <span class="orig-pair-names">@p.TitleA <span class="vs">↔</span> @p.TitleB</span>
                            <span class="orig-bar"><span class="orig-bar-fill @Band(p.Overlap)" style="width:@Pct(p.Overlap)"></span></span>
                            <span class="orig-pair-pct @Band(p.Overlap)">@($"{p.Overlap:P0}")</span>
                        </button>
                    }
                </div>
            }
            @if (hiddenPairs > 0)
            {
                <p class="hint orig-hidden-note">@hiddenPairs pair@(hiddenPairs == 1 ? "" : "s") with no shared text @(hiddenPairs == 1 ? "is" : "are") not shown.</p>
            }
        </div>

        @if (_selected >= 0 && _selected < rep.Pairs.Count)
        {
            var p = rep.Pairs[_selected];
            var textA = _docs[p.IndexA].Text;
            var textB = _docs[p.IndexB].Text;
            <div class="card orig-detail">
                <div class="orig-detail-head">
                    <h3><span class="@Band(p.Overlap)">@($"{p.Overlap:P0}")</span> overlap · @p.TitleA ↔ @p.TitleB</h3>
                    <div class="orig-stats">
                        <span title="Fraction of each document's words inside a shared passage">
                            coverage @($"{p.CoverageA:P0}") / @($"{p.CoverageB:P0}")</span>
                        <span title="Jaccard similarity of the two shingle sets">jaccard @p.Jaccard.ToString("0.00")</span>
                        <span title="Longest single shared run">longest run @p.LongestRunWords words</span>
                    </div>
                </div>

                @if (p.Passages.Count == 0)
                {
                    <p class="empty">No shared passage of @rep.ShingleSize+ words — these two look independent.</p>
                }
                else
                {
                    <div class="orig-side-by-side">
                        <div class="orig-col">
                            <h4>@p.TitleA</h4>
                            <div class="text-view orig-body">
                                @foreach (var seg in Segments(textA, p.Passages.Select(x => x.SpanA)))
                                {
                                    if (seg.Match) { <mark class="orig-hl">@seg.Text</mark> } else { @seg.Text }
                                }
                            </div>
                        </div>
                        <div class="orig-col">
                            <h4>@p.TitleB</h4>
                            <div class="text-view orig-body">
                                @foreach (var seg in Segments(textB, p.Passages.Select(x => x.SpanB)))
                                {
                                    if (seg.Match) { <mark class="orig-hl">@seg.Text</mark> } else { @seg.Text }
                                }
                            </div>
                        </div>
                    </div>

                    <h4 class="orig-passages-h">Shared passages (@p.Passages.Count)</h4>
                    <ul class="orig-passages">
                        @foreach (var pass in p.Passages.OrderByDescending(x => x.WordLength))
                        {
                            <li>
                                <span class="orig-pass-len">@pass.WordLength words</span>
                                <q>@pass.SpanA.Slice(textA)</q>
                            </li>
                        }
                    </ul>
                }

                @if (_embeddingAvailable)
                {
                    <div class="orig-para">
                        <div class="orig-para-head">
                            <h4><Icon Name="beaker" /> Paraphrase check <span class="orig-beta">server · opt-in</span></h4>
                            @if (_paraState != "running")
                            {
                                <button class="ghost sm" @onclick="RunParaphraseCheck">
                                    @(_paraState == "done" ? "Re-run" : "Run deep check")
                                </button>
                            }
                        </div>
                        <p class="hint">
                            Catches <strong>reworded</strong> copies — same idea, different words — that the literal check can't see,
                            and even across languages. This one is <strong>not</strong> on-device: it sends these two documents' sentences to the
                            PeopleWorks server (EmbeddingGemma) to compare their meaning. Nothing is stored.
                        </p>

                        @if (_paraState == "running")
                        {
                            <p class="orig-para-status">Embedding sentences on the server…</p>
                        }
                        else if (_paraState == "error")
                        {
                            <p class="orig-para-status err">@_paraError</p>
                        }
                        else if (_paraState == "done")
                        {
                            @if (_paraMatches.Count == 0)
                            {
                                <p class="empty">No reworded matches above @($"{ParaThreshold:P0}") similarity@(_paraLiteralExcluded > 0 ? $" (beyond the {_paraLiteralExcluded} already shown as literal copies above)" : "").</p>
                            }
                            else
                            {
                                <p class="hint">@_paraMatches.Count reworded sentence pair@(_paraMatches.Count == 1 ? "" : "s") (semantically close but not a literal copy)@(_paraLiteralExcluded > 0 ? $"; {_paraLiteralExcluded} literal match{(_paraLiteralExcluded == 1 ? "" : "es")} shown above {(_paraLiteralExcluded == 1 ? "is" : "are")} omitted here" : "").</p>
                                <ul class="orig-para-list">
                                    @foreach (var m in _paraMatches)
                                    {
                                        <li>
                                            <span class="orig-sim">@($"{m.Similarity:P0}")</span>
                                            <div class="orig-para-texts">
                                                <q class="pa">@m.SpanA.Slice(textA)</q>
                                                <q class="pb">@m.SpanB.Slice(textB)</q>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </div>
                }
            </div>
        }

        <p class="orig-disclaimer">
            <Icon Name="scale" /> This finds text the documents literally share — it is <strong>not</strong> a whole-internet plagiarism
            index, and shared phrasing can be legitimate (quotations, common definitions, a shared assignment prompt).
            Treat the highlights as <strong>evidence to review</strong>, never as a verdict.
        </p>
    </section>
}

@code {
    private sealed class DocEntry
    {
        public string Id { get; } = Guid.NewGuid().ToString("N");
        public string Title { get; set; } = "";
        public string Text { get; set; } = "";
        public string? Note { get; set; }
        // Phase D — web spot-check
        public bool ShowWeb { get; set; }
        public IReadOnlyList<DistinctivePhrase>? WebPhrases { get; set; }
        // Phase D+ — optional automatic server web search
        public bool WebSearching { get; set; }
        public PhraseHitsDto[]? WebHits { get; set; }
        public string? WebError { get; set; }
    }

    private const long MaxFileBytes = 5 * 1024 * 1024;
    private const double ParaThreshold = 0.72; // cosine cutoff: paraphrases ~0.8-0.95, unrelated ~0.4-0.6

    private readonly List<DocEntry> _docs = new() { new(), new() };
    private OriginalityReport? _report;
    private int _selected = -1;
    private string? _batchNote;

    // Phase C — cohort overview
    private double[][]? _overlap;                       // symmetric overlap[i][j] for the heatmap
    private Dictionary<(int, int), int>? _pairAt;       // (min,max doc index) → index into report.Pairs

    // Phase B — server-side paraphrase check (opt-in)
    private string _endpoint = "";
    private bool _embeddingAvailable;
    private string? _embeddingModel;
    private bool _webSearchReady;
    private string _paraState = "idle"; // idle | running | done | error
    private List<ParaphraseMatch> _paraMatches = new();
    private int _paraLiteralExcluded;
    private string? _paraError;

    private int ReadyCount => _docs.Count(d => !string.IsNullOrWhiteSpace(d.Text));

    protected override async Task OnInitializedAsync()
    {
        var settings = await Perplexity.LoadSettingsAsync(Storage);
        _endpoint = settings.Endpoint;
        if (!settings.IsConfigured) return;
        var info = await Perplexity.GetServiceInfoAsync(_endpoint);
        var embed = info?.EmbeddingModels ?? [];
        if (embed.Length > 0)
        {
            _embeddingAvailable = true;
            _embeddingModel = (embed.FirstOrDefault(m => m.IsDefault) ?? embed[0]).Id;
        }
        _webSearchReady = info?.WebSearchReady ?? false;
    }

    private async Task RunAutoWebCheck(DocEntry d)
    {
        if (d.WebPhrases is not { Count: > 0 }) return;
        d.WebSearching = true;
        d.WebError = null;
        StateHasChanged();
        try
        {
            var phrases = d.WebPhrases.Select(p => p.Phrase).ToArray();
            d.WebHits = await WebCheck.CheckAsync(_endpoint, phrases);
        }
        catch (Exception ex)
        {
            d.WebError = ex.Message;
        }
        finally
        {
            d.WebSearching = false;
        }
    }

    private void SelectPair(int idx)
    {
        _selected = idx;
        ResetParaphrase();
    }

    private void ResetParaphrase()
    {
        _paraState = "idle";
        _paraMatches = new();
        _paraLiteralExcluded = 0;
        _paraError = null;
    }

    private async Task RunParaphraseCheck()
    {
        if (_report is null || _selected < 0 || _selected >= _report.Pairs.Count) return;
        var p = _report.Pairs[_selected];
        var textA = _docs[p.IndexA].Text;
        var textB = _docs[p.IndexB].Text;

        var sentsA = new TextDocument(textA).Sentences.Where(s => s.WordCount >= 5).Select(s => s.Span).ToList();
        var sentsB = new TextDocument(textB).Sentences.Where(s => s.WordCount >= 5).Select(s => s.Span).ToList();
        if (sentsA.Count == 0 || sentsB.Count == 0)
        {
            _paraState = "error";
            _paraError = "Need at least one full sentence (5+ words) in each document to compare meaning.";
            return;
        }

        _paraState = "running";
        _paraError = null;
        StateHasChanged();
        try
        {
            var textsA = sentsA.Select(s => s.Slice(textA)).ToArray();
            var textsB = sentsB.Select(s => s.Slice(textB)).ToArray();
            var vecA = await Embedding.EmbedAsync(_endpoint, textsA, _embeddingModel);
            var vecB = await Embedding.EmbedAsync(_endpoint, textsB, _embeddingModel);

            var all = ParaphraseFinder.Find(sentsA, vecA, sentsB, vecB, ParaThreshold, p.Passages.Select(x => x.SpanA));
            _paraMatches = all.Where(m => !m.AlsoLiteral).ToList();
            _paraLiteralExcluded = all.Count(m => m.AlsoLiteral);
            _paraState = "done";
        }
        catch (Exception ex)
        {
            _paraState = "error";
            _paraError = ex.Message;
        }
    }

    private static int WordsOf(string? t) =>
        string.IsNullOrWhiteSpace(t) ? 0 : t.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;

    private void AddDoc() => _docs.Add(new());

    private void ToggleWeb(DocEntry d)
    {
        d.ShowWeb = !d.ShowWeb;
        // Recompute on each open so edits are reflected (extraction is cheap); clear any stale auto-search.
        if (d.ShowWeb)
        {
            d.WebPhrases = DistinctivePhraseExtractor.Extract(d.Text);
            d.WebHits = null;
            d.WebError = null;
        }
    }

    private static string SearchUrl(string engine, string phrase)
    {
        var q = Uri.EscapeDataString("\"" + phrase + "\"");
        return engine switch
        {
            "google" => "https://www.google.com/search?q=" + q,
            "bing" => "https://www.bing.com/search?q=" + q,
            _ => "https://duckduckgo.com/?q=" + q,
        };
    }

    private void RemoveDoc(DocEntry d)
    {
        _docs.Remove(d);
        _report = null;
        _overlap = null;
        _pairAt = null;
        _selected = -1;
        ResetParaphrase();
    }

    private void ClearAll()
    {
        _docs.Clear();
        _docs.Add(new());
        _docs.Add(new());
        _report = null;
        _overlap = null;
        _pairAt = null;
        _selected = -1;
        _batchNote = null;
        ResetParaphrase();
    }

    private void Compare()
    {
        var inputs = new List<OriginalityInput>();
        int n = 0;
        foreach (var d in _docs)
        {
            if (string.IsNullOrWhiteSpace(d.Text)) continue;
            n++;
            var title = string.IsNullOrWhiteSpace(d.Title) ? $"Document {n}" : d.Title.Trim();
            inputs.Add(new OriginalityInput(d.Id, title, d.Text));
        }
        if (inputs.Count < 2) { _report = null; _selected = -1; return; }

        _report = Checker.Check(inputs);
        BuildMatrix(_report);
        _selected = _report.Pairs.Count > 0 ? 0 : -1;
        ResetParaphrase();
    }

    private void BuildMatrix(OriginalityReport rep)
    {
        int n = rep.DocumentCount;
        _overlap = new double[n][];
        for (int i = 0; i < n; i++) _overlap[i] = new double[n];
        _pairAt = new Dictionary<(int, int), int>();
        for (int k = 0; k < rep.Pairs.Count; k++)
        {
            var p = rep.Pairs[k];
            _overlap[p.IndexA][p.IndexB] = p.Overlap;
            _overlap[p.IndexB][p.IndexA] = p.Overlap;
            _pairAt[(Math.Min(p.IndexA, p.IndexB), Math.Max(p.IndexA, p.IndexB))] = k;
        }
    }

    private void SelectPairByCell(int i, int j)
    {
        if (i == j || _pairAt is null) return;
        if (_pairAt.TryGetValue((Math.Min(i, j), Math.Max(i, j)), out var idx))
            SelectPair(idx);
    }

    private async Task OnBatchFiles(InputFileChangeEventArgs e)
    {
        _batchNote = null;
        int added = 0, skipped = 0;
        foreach (var file in e.GetMultipleFiles(200))
        {
            if (file.Size > MaxFileBytes) { skipped++; continue; }
            try
            {
                string text;
                if (file.Name.EndsWith(".docx", StringComparison.OrdinalIgnoreCase))
                {
                    await using var s = file.OpenReadStream(MaxFileBytes);
                    text = await DocxTextExtractor.ExtractTextAsync(s);
                }
                else
                {
                    using var reader = new StreamReader(file.OpenReadStream(MaxFileBytes));
                    text = await reader.ReadToEndAsync();
                }
                if (string.IsNullOrWhiteSpace(text)) { skipped++; continue; }
                _docs.Add(new DocEntry { Title = Path.GetFileNameWithoutExtension(file.Name), Text = text });
                added++;
            }
            catch { skipped++; }
        }
        // Drop the empty starter slots once real documents have arrived.
        if (added > 0) _docs.RemoveAll(d => string.IsNullOrWhiteSpace(d.Text));
        _batchNote = $"Added {added} document{(added == 1 ? "" : "s")}" + (skipped > 0 ? $" ({skipped} skipped)" : "") + ".";
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e, DocEntry d)
    {
        var file = e.File;
        if (file is null) return;
        d.Note = null;
        if (file.Size > MaxFileBytes) { d.Note = $"“{file.Name}” is too large (max 5 MB)."; return; }
        try
        {
            if (file.Name.EndsWith(".docx", StringComparison.OrdinalIgnoreCase))
            {
                await using var s = file.OpenReadStream(MaxFileBytes);
                d.Text = await DocxTextExtractor.ExtractTextAsync(s);
            }
            else
            {
                using var reader = new StreamReader(file.OpenReadStream(MaxFileBytes));
                d.Text = await reader.ReadToEndAsync();
            }
            if (string.IsNullOrWhiteSpace(d.Title))
                d.Title = Path.GetFileNameWithoutExtension(file.Name);
            d.Note = $"Loaded “{file.Name}” ({file.Size / 1024} KB).";
        }
        catch (Exception ex) { d.Note = $"Could not read the file: {ex.Message}"; }
    }

