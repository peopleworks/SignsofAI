@* Our own minimal line-icon set — no emoji. This is a tool that flags AI-writing tells (and emoji
   are one of them), so the UI carries hand-drawn SVG glyphs instead. Each icon is stroke-based
   (stroke = currentColor), sized to 1em, and inherits the surrounding text color, so it drops into
   any button or heading and themes automatically in light/dark. *@
<svg class="icon @Class" viewBox="0 0 24 24" width="1em" height="1em" fill="none"
     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
     aria-hidden="true" focusable="false">@((MarkupString)Glyph(Name))</svg>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";

    /// <summary>Extra CSS class(es) for sizing/spacing tweaks.</summary>
    [Parameter] public string? Class { get; set; }

    private static string Glyph(string name) => name switch
    {
